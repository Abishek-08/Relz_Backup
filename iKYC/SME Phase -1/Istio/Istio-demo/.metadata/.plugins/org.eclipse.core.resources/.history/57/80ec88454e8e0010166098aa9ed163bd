apiVersion: apps/v1
kind: Deployment
metadata:
  name: booking-service
  namespace: istio-microservice
spec:
  replicas: 2
  template:
    metadata:
      labels:
        app: booking-service
        version: v1
    spec:
      containers:
      - name: booking-service
        image: booking-service-image:1.0
        
---
apiVersion: v1
kind: Service
metadata:
  name: booking-service
spec:
  ports:
  - port: 8020
    targetPort: 8020
    protocol: TCP
    name: http
  selector:
    app: booking-service